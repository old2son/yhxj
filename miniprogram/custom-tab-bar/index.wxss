.tabbar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    height: calc(112rpx + env(safe-area-inset-bottom));
    padding: 0 18rpx env(safe-area-inset-bottom);
    background: rgba(2, 6, 23, 0.96);
    border-top: 1rpx solid rgba(255, 255, 255, 0.06);
    box-sizing: border-box;
}

.tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10rpx;
    color: #71717a;
}

.tab-item-active {
    color: #22d3ee;
}

.tab-icon {
    position: relative;
    width: 42rpx;
    height: 42rpx;
}

.tab-text {
    font-size: 20rpx;
}

.tab-icon-home .home-body,
.tab-icon-home .home-window,
.tab-icon-home .home-flame,
.tab-icon-orbit .orbit-ring,
.tab-icon-orbit .orbit-planet,
.tab-icon-game .game-body,
.tab-icon-game .game-pad,
.tab-icon-game .game-dot {
    position: absolute;
}

.tab-icon-home .home-body {
    left: 12rpx;
    top: 4rpx;
    width: 18rpx;
    height: 24rpx;
    border-radius: 12rpx 12rpx 8rpx 8rpx;
    background: currentColor;
    transform: rotate(18deg);
}

.tab-icon-home .home-window {
    left: 18rpx;
    top: 10rpx;
    width: 6rpx;
    height: 6rpx;
    border-radius: 50%;
    background: rgba(2, 6, 23, 0.9);
}

.tab-icon-home .home-flame {
    left: 14rpx;
    top: 26rpx;
    width: 10rpx;
    height: 12rpx;
    border-radius: 0 0 10rpx 10rpx;
    background: linear-gradient(180deg, #f59e0b 0%, #fb7185 100%);
}

.tab-icon-orbit .orbit-ring {
    left: 5rpx;
    top: 10rpx;
    width: 30rpx;
    height: 18rpx;
    border: 3rpx solid currentColor;
    border-radius: 50%;
    transform: rotate(-22deg);
}

.tab-icon-orbit .orbit-planet {
    right: 6rpx;
    top: 8rpx;
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 10rpx currentColor;
}

.tab-icon-game .game-body {
    left: 5rpx;
    top: 10rpx;
    width: 32rpx;
    height: 20rpx;
    border-radius: 14rpx 14rpx 18rpx 18rpx;
    border: 3rpx solid currentColor;
}

.tab-icon-game .game-pad-h {
    left: 12rpx;
    top: 18rpx;
    width: 10rpx;
    height: 3rpx;
    border-radius: 999rpx;
    background: currentColor;
}

.tab-icon-game .game-pad-v {
    left: 15rpx;
    top: 15rpx;
    width: 3rpx;
    height: 10rpx;
    border-radius: 999rpx;
    background: currentColor;
}

.tab-icon-game .game-dot {
    width: 5rpx;
    height: 5rpx;
    border-radius: 50%;
    background: currentColor;
}

.tab-icon-game .game-dot-1 {
    right: 12rpx;
    top: 16rpx;
}

.tab-icon-game .game-dot-2 {
    right: 8rpx;
    top: 22rpx;
}
