page {
    height: 100%;
}

.page-shell {
    position: relative;
    height: 100vh;
    overflow: hidden;
    background:
        radial-gradient(circle at top, rgba(34, 211, 238, 0.12), transparent 28%),
        radial-gradient(circle at bottom, rgba(244, 114, 182, 0.14), transparent 34%),
        linear-gradient(180deg, #02020a 0%, #03001e 56%, #020617 100%);
    color: #ffffff;
}

.game-head {
    position: relative;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24rpx 30rpx 18rpx;
    background: rgba(2, 6, 23, 0.88);
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.game-stats {
    display: flex;
    align-items: center;
    gap: 30rpx;
}

.stat-block {
    display: flex;
    align-items: baseline;
    gap: 10rpx;
}

.stat-label {
    font-size: 22rpx;
    color: #71717a;
}

.stat-value {
    font-size: 30rpx;
    color: #22d3ee;
    font-weight: 700;
}

.stat-life {
    font-size: 28rpx;
    color: #fb7185;
    letter-spacing: 4rpx;
}

.control-btn {
    padding: 16rpx 24rpx;
    border-radius: 18rpx;
    background: linear-gradient(90deg, #0891b2 0%, #4f46e5 100%);
    font-size: 22rpx;
    font-weight: 600;
}

.game-stage {
    position: relative;
    z-index: 5;
    height: calc(100vh - 114rpx - 112rpx - env(safe-area-inset-bottom));
    margin: 22rpx 24rpx 0;
    overflow: hidden;
    border-radius: 36rpx;
    background: rgba(15, 23, 42, 0.74);
    border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.game-canvas {
    display: block;
    position: absolute;
    top: 0;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
}

.game-canvas-hidden {
    top: -9999rpx;
    opacity: 0;
    pointer-events: none;
}

.guide-overlay,
.gameover-overlay {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 50rpx;
    text-align: center;
}

.guide-overlay {
    background: rgba(0, 0, 0, 0.68);
}

.gameover-overlay {
    background: rgba(0, 0, 0, 0.82);
    backdrop-filter: blur(12rpx);
}

.guide-icon,
.gameover-icon {
    position: relative;
    width: 112rpx;
    height: 112rpx;
    border-radius: 50%;
    margin-bottom: 26rpx;
    background: rgba(244, 114, 182, 0.12);
    color: #f472b6;
}

.gameover-icon {
    width: 128rpx;
    height: 128rpx;
    margin-bottom: 22rpx;
    background: rgba(244, 63, 94, 0.14);
    box-shadow: 0 0 0 2rpx rgba(244, 63, 94, 0.08) inset;
}

.gameover-badge {
    padding: 8rpx 18rpx;
    border-radius: 999rpx;
    background: rgba(244, 63, 94, 0.12);
    border: 1rpx solid rgba(244, 63, 94, 0.2);
    color: #fb7185;
    font-size: 18rpx;
    font-weight: 700;
    letter-spacing: 2rpx;
}

.guide-title,
.gameover-title {
    font-size: 34rpx;
    font-weight: 700;
}

.gameover-title {
    margin-top: 20rpx;
    font-size: 40rpx;
}

.guide-desc,
.gameover-desc {
    max-width: 86%;
    margin-top: 18rpx;
    font-size: 24rpx;
    line-height: 1.8;
    color: #a1a1aa;
}

.guide-tip {
    margin-top: 28rpx;
    padding: 16rpx 24rpx;
    border-radius: 999rpx;
    background: rgba(255, 255, 255, 0.06);
    border: 1rpx solid rgba(255, 255, 255, 0.06);
    font-size: 20rpx;
    color: #94a3b8;
}

.score-card {
    width: 336rpx;
    margin-top: 28rpx;
    padding: 30rpx 24rpx;
    border-radius: 28rpx;
    background: rgba(255, 255, 255, 0.06);
    border: 1rpx solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 18rpx 40rpx rgba(2, 6, 23, 0.28);
    text-align: center;
}

.score-card-label {
    font-size: 20rpx;
    color: #a1a1aa;
    letter-spacing: 2rpx;
}

.score-card-value {
    margin-top: 10rpx;
    font-size: 60rpx;
    font-weight: 700;
    color: #22d3ee;
    text-shadow: 0 0 18rpx rgba(34, 211, 238, 0.22);
}

.restart-btn {
    margin-top: 28rpx;
    min-width: 260rpx;
    padding: 24rpx 54rpx;
    border-radius: 24rpx;
    background: linear-gradient(90deg, #06b6d4 0%, #8b5cf6 100%);
    font-size: 24rpx;
    font-weight: 600;
    text-align: center;
    box-shadow: 0 18rpx 36rpx rgba(8, 145, 178, 0.24);
}

.tabbar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    height: calc(112rpx + env(safe-area-inset-bottom));
    padding: 0 18rpx env(safe-area-inset-bottom);
    background: rgba(2, 6, 23, 0.94);
    border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10rpx;
    color: #71717a;
}

.tab-item-active {
    color: #22d3ee;
}

.tab-icon {
    position: relative;
    width: 42rpx;
    height: 42rpx;
}

.tab-text {
    font-size: 20rpx;
}

.tab-icon-home .home-body,
.tab-icon-home .home-window,
.tab-icon-home .home-flame,
.tab-icon-orbit .orbit-ring,
.tab-icon-orbit .orbit-planet,
.tab-icon-game .game-body,
.tab-icon-game .game-pad,
.tab-icon-game .game-dot,
.gameover-icon .skull-head,
.gameover-icon .skull-eye,
.gameover-icon .skull-mouth,
.gameover-icon .cross-bone,
.gameover-icon .bone-dot {
    position: absolute;
}

.tab-icon-home .home-body {
    left: 12rpx;
    top: 4rpx;
    width: 18rpx;
    height: 24rpx;
    border-radius: 12rpx 12rpx 8rpx 8rpx;
    background: currentColor;
    transform: rotate(18deg);
}

.tab-icon-home .home-window {
    left: 18rpx;
    top: 10rpx;
    width: 6rpx;
    height: 6rpx;
    border-radius: 50%;
    background: rgba(2, 6, 23, 0.9);
}

.tab-icon-home .home-flame {
    left: 14rpx;
    top: 26rpx;
    width: 10rpx;
    height: 12rpx;
    border-radius: 0 0 10rpx 10rpx;
    background: linear-gradient(180deg, #f59e0b 0%, #fb7185 100%);
}

.tab-icon-orbit .orbit-ring {
    left: 5rpx;
    top: 10rpx;
    width: 30rpx;
    height: 18rpx;
    border: 3rpx solid currentColor;
    border-radius: 50%;
    transform: rotate(-22deg);
}

.tab-icon-orbit .orbit-planet {
    right: 6rpx;
    top: 8rpx;
    width: 10rpx;
    height: 10rpx;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 10rpx currentColor;
}

.tab-icon-game .game-body,
.guide-icon .game-body {
    left: 5rpx;
    top: 10rpx;
    width: 32rpx;
    height: 20rpx;
    border-radius: 14rpx 14rpx 18rpx 18rpx;
    border: 3rpx solid currentColor;
}

.guide-icon .game-body {
    left: 26rpx;
    top: 34rpx;
    width: 60rpx;
    height: 34rpx;
    border-width: 4rpx;
}

.tab-icon-game .game-pad-h,
.guide-icon .game-pad-h {
    left: 12rpx;
    top: 18rpx;
    width: 10rpx;
    height: 3rpx;
    border-radius: 999rpx;
    background: currentColor;
}

.tab-icon-game .game-pad-v,
.guide-icon .game-pad-v {
    left: 15rpx;
    top: 15rpx;
    width: 3rpx;
    height: 10rpx;
    border-radius: 999rpx;
    background: currentColor;
}

.guide-icon .game-pad-h {
    left: 40rpx;
    top: 49rpx;
    width: 18rpx;
    height: 4rpx;
}

.guide-icon .game-pad-v {
    left: 47rpx;
    top: 42rpx;
    width: 4rpx;
    height: 18rpx;
}

.tab-icon-game .game-dot,
.guide-icon .game-dot {
    width: 5rpx;
    height: 5rpx;
    border-radius: 50%;
    background: currentColor;
}

.tab-icon-game .game-dot-1 {
    right: 12rpx;
    top: 16rpx;
}

.tab-icon-game .game-dot-2 {
    right: 8rpx;
    top: 22rpx;
}

.guide-icon .game-dot-1 {
    right: 38rpx;
    top: 44rpx;
    width: 8rpx;
    height: 8rpx;
}

.guide-icon .game-dot-2 {
    right: 28rpx;
    top: 54rpx;
    width: 8rpx;
    height: 8rpx;
}

.skull-head {
    left: 34rpx;
    top: 26rpx;
    width: 60rpx;
    height: 48rpx;
    border-radius: 28rpx 28rpx 20rpx 20rpx;
    background: #fb7185;
}

.skull-eye {
    top: 16rpx;
    width: 10rpx;
    height: 14rpx;
    border-radius: 50%;
    background: #1f2937;
}

.skull-eye-1 {
    left: 16rpx;
}

.skull-eye-2 {
    right: 16rpx;
}

.skull-mouth {
    left: 22rpx;
    bottom: 10rpx;
    width: 16rpx;
    height: 6rpx;
    border-radius: 999rpx;
    background: #1f2937;
}

.cross-bone {
    left: 44rpx;
    bottom: 20rpx;
    width: 40rpx;
    height: 8rpx;
    border-radius: 999rpx;
    background: rgba(251, 113, 133, 0.9);
}

.bone-dot {
    top: -5rpx;
    width: 18rpx;
    height: 18rpx;
    border-radius: 50%;
    background: rgba(251, 113, 133, 0.9);
}

.bone-dot-a {
    left: -6rpx;
}

.bone-dot-b {
    right: -6rpx;
}

.cross-bone-1 {
    transform: rotate(32deg);
}

.cross-bone-2 {
    transform: rotate(-32deg);
}
